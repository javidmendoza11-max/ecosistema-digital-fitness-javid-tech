                    state.db = data;
                    
                    // Configurar UI Global
                    document.getElementById('login-screen').classList.add('hidden');
                    document.getElementById('app-container').classList.remove('hidden');
                    document.getElementById('ui-username').innerText = state.user.nombre;
                    document.getElementById('ui-role').innerText = state.user.rol;
                    document.getElementById('ui-avatar').innerText = state.user.nombre.substring(0,2).toUpperCase();
                    
