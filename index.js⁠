                \`;
            }

            async function guardarModoDios() {
                try {
                    const newFeed = {
                        titulo: document.getElementById('adm-feed-tit').value,
                        descripcion: document.getElementById('adm-feed-desc').value,
                        videoUrl: state.db.feed.videoUrl
                    };
                    const newProgs = JSON.parse(document.getElementById('adm-prog-json').value);

                    const res = await apiFetch('/api/admin/actualizar', 'POST', { feed: newFeed, programas: newProgs });
                    
                    if(res && res.success) {
                        alert("✅ Código inyectado exitosamente en el Ecosistema.");
                        await cargarBaseDeDatos(); // Recargar todo
                    } else {
                        alert("❌ Error de permisos o servidor.");
                    }
                } catch (e) {
                    alert("🔥 ERROR DE SINTAXIS JSON. Revisa las comillas y comas del código antes de inyectar.");
                }
            }
        </script>
        <style>
            @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        </style>
    </body>
    </html>
    `);
});

