                                \`;
                            });
                            checklistHtml += \`</div>\`;
                        }

                        const pdfHtml = mod.pdfUrl ? \`<button class="btn-outline" style="width:100%; margin-top:20px; font-size:12px;" onclick="window.open('\${mod.pdfUrl}')">📄 Descargar Material Estructural</button>\` : '';

                        html += \`
                            <div class="module-wrapper">
                                <h2 style="font-size: 24px; font-weight: 900; text-transform: uppercase; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                                    <span style="color:var(--gold-primary)">|</span> \${mod.titulo}
                                </h2>
                                <div class="module-content">\${mod.contenido}</div>
                                \${pdfHtml}
                                \${checklistHtml}
                            </div>
                        \`;
                    });
                }

                html += \`</div>\`;
                main.innerHTML = html;
                window.scrollTo(0,0);
            }

            // --- LÓGICA DE GAMIFICACIÓN AL VUELO ---
            async function toggleChecklist(progKey, modKey, taskIndex) {
                const checkElement = document.getElementById(\`check-\${modKey}-\${taskIndex}\`);
                const wasCompleted = checkElement.classList.contains('completed');
                const isNowCompleted = !wasCompleted;
                
                // UI Inmediata (Optimista)
                if (isNowCompleted) checkElement.classList.add('completed');
                else checkElement.classList.remove('completed');

                // Enviar a Backend de forma silenciosa
                const res = await apiFetch('/api/ecosistema/progreso', 'POST', {
                    userId: state.user.id,
                    fecha: state.fechaHoy,
                    moduloKey: modKey,
                    taskIndex: taskIndex,
                    valor: isNowCompleted
                });

                if (res && res.success) {
                    // Actualizar estado local
                    if(!state.db.cache_usuarios[state.user.id]) state.db.cache_usuarios[state.user.id] = {};
                    state.db.cache_usuarios[state.user.id][state.fechaHoy] = res.cacheDia;
                    actualizarPanelLateral(); // Recalcula barras y calendarios
                }
            }

            function actualizarPanelLateral() {
                const panel = document.getElementById('panel-gamificacion');
                const userCache = state.db.cache_usuarios[state.user.id] || {};
                
                // LÓGICA MATEMÁTICA: 12 Semanas = 84 Días. 
                // Contamos cuántos días distintos tienen al menos un checklist en true.
                let diasCompletados = 0;
                Object.values(userCache).forEach(diaObj => {
                    let cumplioDia = false;
                    Object.values(diaObj).forEach(modObj => {
                        Object.values(modObj).forEach(val => { if (val) cumplioDia = true; });
                    });
                    if (cumplioDia) diasCompletados++;
                });

                const porcentaje = Math.min(100, Math.round((diasCompletados / 84) * 100));

                // LÓGICA CALENDARIO: Últimos 14 días
                let calHtml = '';
                let d = new Date(state.fechaHoy);
                d.setDate(d.getDate() - 13);
                
                for(let i=0; i<14; i++) {
                    const dateStr = d.toISOString().split('T')[0];
                    let css = "cal-day";
                    if (dateStr === state.fechaHoy) css += " today";
                    
                    // Comprobar si ese día hubo actividad
                    if(userCache[dateStr]) {
                        let activo = false;
                        Object.values(userCache[dateStr]).forEach(modObj => {
                            Object.values(modObj).forEach(val => { if(val) activo = true; });
                        });
                        if (activo) css += " active";
                    }

                    calHtml += \`<div class="\${css}" title="\${dateStr}">\${d.getDate()}</div>\`;
                    d.setDate(d.getDate() + 1);
                }

                panel.innerHTML = \`
                    <div class="progress-container">
                        <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px;">
                            <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted);">Progreso (12 Semanas)</span>
                            <span style="font-size: 32px; font-weight: 900; color: var(--gold-primary);">\${porcentaje}%</span>
                        </div>
                        <div class="progress-track"><div class="progress-fill" style="width: \${porcentaje}%"></div></div>
                        <p style="font-size: 11px; color: #555; margin-top: 15px; text-align: center;">\${diasCompletados} de 84 días estructurales completados.</p>
                    </div>

                    <div class="progress-container">
                        <h4 style="font-size: 12px; color: var(--gold-primary); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px; text-align: center;">Heatmap Histórico</h4>
                        <div class="calendar-grid">\${calHtml}</div>
                    </div>
                \`;
            }

            function togglePanel() {
                document.getElementById('side-panel').classList.toggle('active');
            }

            // --- CMS: MODO DIOS (Solo Admin) ---
            function renderAdmin() {
                const main = document.getElementById('main-view');
