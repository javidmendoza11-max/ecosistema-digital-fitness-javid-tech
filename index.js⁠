const express = require('express');
const cors = require('cors');
const fs = require('fs');
const path = require('path');
const jwt = require('jsonwebtoken');

const app = express();

// --- 1. MIDDLEWARES & CONFIGURACIÓN DE SEGURIDAD ---
app.use(cors());
app.use(express.json({ limit: '50mb' })); // Capacidad ampliada para guardar JSONs gigantes
app.use(express.urlencoded({ extended: true }));

const SECRET_KEY = "JavidMendoza_Matriz_V10_UltraSecureKey_2026";
const DB_FILE = path.join(__dirname, 'database.json');

// --- 2. MOTOR DE PERSISTENCIA ATÓMICA ---
// Garantiza que la lectura y escritura de tus 1600+ líneas sea segura
function getDatabase() {
    try {
        const data = fs.readFileSync(DB_FILE, 'utf8');
        return JSON.parse(data);
    } catch (error) {
        console.error("🔥 Error crítico leyendo database.json:", error);
        return null;
    }
}

function saveDatabase(db) {
    try {
        fs.writeFileSync(DB_FILE, JSON.stringify(db, null, 2));
        return true;
    } catch (error) {
        console.error("🔥 Error crítico guardando database.json:", error);
        return false;
    }
}

// --- 3. MIDDLEWARE DE AUTENTICACIÓN JWT ---
function verificarToken(req, res, next) {
    const bearerHeader = req.headers['authorization'];
    if (typeof bearerHeader !== 'undefined') {
        const bearer = bearerHeader.split(' ');
        const bearerToken = bearer[1];
        jwt.verify(bearerToken, SECRET_KEY, (err, authData) => {
            if (err) return res.status(403).json({ success: false, message: 'Token inválido o expirado' });
            req.usuarioAuth = authData;
            next();
        });
    } else {
        res.status(403).json({ success: false, message: 'Acceso Denegado. Token no proporcionado.' });
    }
}

// --- 4. ENDPOINTS API RESTFUL ---

// Endpoint: Autenticación
app.post('/api/auth/login', (req, res) => {
    const db = getDatabase();
    if (!db) return res.status(500).json({ success: false, message: "Error de servidor" });

    const { username, password } = req.body;
    const user = db.usuarios.find(u => u.username === username && u.password === password);
    
    if (user) {
        // Firmamos el token por 7 días para que el alumno no tenga que loguearse a diario
        const token = jwt.sign({ id: user.id, rol: user.rol }, SECRET_KEY, { expiresIn: '7d' });
        // No enviamos la contraseña al frontend por seguridad
        const { password: _, ...usuarioSeguro } = user; 
        res.json({ success: true, token, usuario: usuarioSeguro });
    } else {
        res.status(401).json({ success: false, message: "Credenciales de élite incorrectas." });
    }
});

// Endpoint: Obtener Ecosistema Completo (Protegido)
app.get('/api/ecosistema/datos', verificarToken, (req, res) => {
    const db = getDatabase();
    res.json(db);
});

// Endpoint: Guardar Gamificación / Checklists (Protegido)
app.post('/api/ecosistema/progreso', verificarToken, (req, res) => {
    const { userId, fecha, moduloKey, taskIndex, valor } = req.body;
    
    // Validar que el usuario solo modifique su propio caché (o si es admin)
    if (req.usuarioAuth.id !== userId && req.usuarioAuth.rol !== 'admin') {
        return res.status(403).json({ success: false, message: 'Operación no autorizada.' });
    }

    const db = getDatabase();
    if (!db.cache_usuarios[userId]) db.cache_usuarios[userId] = {};
    if (!db.cache_usuarios[userId][fecha]) db.cache_usuarios[userId][fecha] = {};
    if (!db.cache_usuarios[userId][fecha][moduloKey]) db.cache_usuarios[userId][fecha][moduloKey] = {};
    
    db.cache_usuarios[userId][fecha][moduloKey][taskIndex] = valor;
    
    if (saveDatabase(db)) {
        res.json({ success: true, cacheDia: db.cache_usuarios[userId][fecha] });
    } else {
        res.status(500).json({ success: false, message: "Error al sincronizar matriz." });
    }
});

// Endpoint: Modo Dios CMS - Sobreescribir Data (Protegido - Solo Admin)
app.post('/api/admin/actualizar', verificarToken, (req, res) => {
    if (req.usuarioAuth.rol !== 'admin') {
        return res.status(403).json({ success: false, message: 'Requiere privilegios MODO DIOS.' });
    }

    const db = getDatabase();
    db.feed = req.body.feed;
    db.programas = req.body.programas;
    
    if (saveDatabase(db)) {
        res.json({ success: true, message: "Matriz global actualizada con éxito." });
    } else {
        res.status(500).json({ success: false, message: "Error en inyección de código." });
    }
});

